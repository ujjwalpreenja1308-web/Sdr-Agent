{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "paths": {
      "@pipeiq/shared": ["../../packages/shared/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
